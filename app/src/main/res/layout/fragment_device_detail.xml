<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_header_gradient" android:orientation="vertical" android:padding="18dp">
      <TextView android:id="@+id/tvDeviceName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_blue_text" android:textSize="20sp" android:textStyle="bold" />
      <TextView android:id="@+id/tvDeviceType" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" />
      <TextView android:id="@+id/tvDeviceLocation" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" />
      <TextView android:id="@+id/tvDeviceStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:padding="8dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal">
      <TextView android:id="@+id/tvDevicePower" android:layout_width="0dp" android:layout_height="72dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:background="@drawable/bg_metric_primary" android:gravity="center" android:textColor="@color/text_primary" android:textStyle="bold" />
      <TextView android:id="@+id/tvDeviceToday" android:layout_width="0dp" android:layout_height="72dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:background="@drawable/bg_metric_mint" android:gravity="center" android:textColor="@color/text_primary" android:textStyle="bold" />
      <TextView android:id="@+id/tvDeviceMonth" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:background="@drawable/bg_metric_pink" android:gravity="center" android:textColor="@color/text_primary" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:id="@+id/tvDeviceAction" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_soft_panel" android:padding="14dp" android:textColor="@color/brand_blue_text" />
    <TextView android:id="@+id/tvDeviceNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_metric_soft" android:padding="16dp" android:textColor="@color/text_primary" />
    <TextView android:id="@+id/tvDeviceLatestAlert" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/text_primary" />
    <TextView android:id="@+id/tvDeviceLastInspection" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal">
      <com.google.android.material.button.MaterialButton android:id="@+id/btnAskDeviceAssistant" style="@style/Widget.Traffic.SecondaryButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:layout_weight="1" android:text="问助手" />
      <com.google.android.material.button.MaterialButton android:id="@+id/btnCreateDeviceWorkOrder" style="@style/Widget.Traffic.PrimaryButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="生成工单" />
    </LinearLayout>
  </LinearLayout>
</ScrollView>
