<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:padding="20dp">

  <TextView
    android:id="@+id/tvFeedbackTitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textColor="@color/text_primary"
    android:textSize="19sp"
    android:textStyle="bold" />

  <com.google.android.material.textfield.TextInputLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:hint="处置说明">

    <com.google.android.material.textfield.TextInputEditText
      android:id="@+id/etProcessMessage"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="top"
      android:minLines="4" />
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.button.MaterialButton
    android:id="@+id/btnPickProcessImage"
    style="@style/Widget.Traffic.SecondaryButton"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:text="上传图片" />

  <TextView
    android:id="@+id/tvProcessImageName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="未选择图片"
    android:textColor="@color/text_secondary"
    android:textSize="13sp" />

  <ImageView
    android:id="@+id/ivProcessImagePreview"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_soft_panel"
    android:contentDescription="处置图片预览"
    android:scaleType="centerCrop"
    android:visibility="gone" />
</LinearLayout>
