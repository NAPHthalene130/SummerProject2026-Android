<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
      android:id="@+id/tvDialogOrderCode"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/text_tertiary"
      android:textSize="12sp" />

    <TextView
      android:id="@+id/tvDialogTaskTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textColor="@color/text_primary"
      android:textSize="21sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/tvDialogStatus"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:background="@drawable/bg_soft_panel"
      android:padding="8dp"
      android:textColor="@color/brand_blue_text"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/tvDialogMeta"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:textColor="@color/text_secondary"
      android:textSize="14sp" />

    <TextView
      android:id="@+id/tvDialogDescription"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/bg_soft_panel"
      android:padding="14dp"
      android:textColor="@color/text_primary" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="AI 处置建议"
      android:textColor="@color/text_primary"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/tvDialogAiSuggestion"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:background="@drawable/bg_metric_mint"
      android:padding="14dp"
      android:textColor="@color/text_primary" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="现场信息"
      android:textColor="@color/text_primary"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/tvDialogSceneInfo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textColor="@color/text_secondary" />

    <HorizontalScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:scrollbars="none">

      <LinearLayout
        android:id="@+id/layoutSceneImages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
      android:id="@+id/layoutProcessRecord"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:background="@drawable/bg_metric_mint"
      android:orientation="vertical"
      android:padding="14dp"
      android:visibility="gone">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="处置记录"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/tvDialogProcessRecord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/layoutOrderActions"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:orientation="vertical">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogProcessing"
        style="@style/Widget.Traffic.SecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="标记处理中" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnDialogComplete"
          style="@style/Widget.Traffic.PrimaryButton"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginEnd="6dp"
          android:layout_weight="1"
          android:text="完成" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnDialogFalseAlarm"
          style="@style/Widget.Traffic.SecondaryButton"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="6dp"
          android:layout_weight="1"
          android:text="误报" />
      </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
      android:id="@+id/btnCancel"
      style="@style/Widget.Traffic.SecondaryButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:text="关闭" />
  </LinearLayout>
</ScrollView>
