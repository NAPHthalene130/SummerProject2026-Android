<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="24dp" />
      <gradient
        android:angle="315"
        android:endColor="@color/brand_blue_dark"
        android:startColor="@color/brand_blue" />
      <stroke
        android:color="@color/card_stroke"
        android:width="1dp" />
    </shape>
  </item>

  <item
    android:gravity="top|end"
    android:height="72dp"
    android:right="14dp"
    android:top="14dp"
    android:width="72dp">
    <shape android:shape="oval">
      <solid android:color="#26FFFFFF" />
    </shape>
  </item>

  <item
    android:gravity="bottom|start"
    android:bottom="12dp"
    android:height="28dp"
    android:left="12dp"
    android:width="28dp">
    <shape android:shape="oval">
      <solid android:color="#1EFFFFFF" />
    </shape>
  </item>
</layer-list>


