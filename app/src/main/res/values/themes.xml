<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="Theme.TrafficManagementAndroid" parent="Theme.Material3.Light.NoActionBar">
    <item name="colorPrimary">@color/brand_blue</item>
    <item name="colorSecondary">@color/brand_blue</item>
    <item name="colorSurface">@color/white</item>
    <item name="colorSurfaceContainer">@color/surface_secondary</item>
    <item name="colorOutline">@color/card_stroke</item>
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    <item name="android:navigationBarColor">@color/page_background</item>
    <item name="android:windowBackground">@color/page_background</item>
    <item name="materialButtonStyle">@style/Widget.Traffic.PrimaryButton</item>
  </style>

  <style name="Widget.Traffic.PrimaryButton" parent="Widget.Material3.Button">
    <item name="android:textAllCaps">false</item>
    <item name="android:minHeight">52dp</item>
    <item name="backgroundTint">@color/brand_blue</item>
    <item name="cornerRadius">18dp</item>
    <item name="android:textColor">@color/brand_blue_text</item>
    <item name="iconTint">@color/brand_blue_text</item>
  </style>

  <style name="Widget.Traffic.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
    <item name="android:textAllCaps">false</item>
    <item name="android:minHeight">52dp</item>
    <item name="backgroundTint">@color/white</item>
    <item name="strokeColor">@color/card_stroke</item>
    <item name="strokeWidth">1dp</item>
    <item name="cornerRadius">18dp</item>
    <item name="android:textColor">@color/text_primary</item>
    <item name="iconTint">@color/brand_blue_text</item>
  </style>

  <style name="Widget.Traffic.ActionButton" parent="Widget.Material3.Button">
    <item name="android:textAllCaps">false</item>
    <item name="android:minHeight">96dp</item>
    <item name="android:gravity">start|center_vertical</item>
    <item name="backgroundTint">@color/action_blue_bg</item>
    <item name="cornerRadius">24dp</item>
    <item name="android:textColor">@color/text_primary</item>
    <item name="iconPadding">12dp</item>
    <item name="iconGravity">textStart</item>
  </style>

  <style name="Widget.Traffic.ChipButton" parent="Widget.Material3.Button.OutlinedButton">
    <item name="android:textAllCaps">false</item>
    <item name="android:minHeight">44dp</item>
    <item name="backgroundTint">@color/white</item>
    <item name="strokeColor">@color/card_stroke</item>
    <item name="strokeWidth">1dp</item>
    <item name="cornerRadius">18dp</item>
    <item name="android:textColor">@color/text_primary</item>
    <item name="iconTint">@color/brand_blue_text</item>
  </style>
</resources>


